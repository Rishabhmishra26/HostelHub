# ------------------------------------------------------------------
# HostelHub environment variables
# Copy this file to ".env.local" and fill in real values.
# ------------------------------------------------------------------

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/hostelhub

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Only students with this email domain can register
ALLOWED_EMAIL_DOMAIN=college.edu

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Nodemailer (used to send OTP / reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Google Gemini API key (AI-assisted complaint writing)
GEMINI_API_KEY=your-gemini-api-key

# Public base URL (used in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
